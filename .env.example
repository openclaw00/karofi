PORT=4173

# Supabase order database.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ORDERS_TABLE=orders

# Email notifications via Resend.
RESEND_API_KEY=re_xxxxxxxxx
ORDER_EMAIL_TO=you@example.com
ORDER_EMAIL_FROM=Karofi Store <orders@yourdomain.com>

# Required online for orders.html and GET /api/orders.
ADMIN_ORDERS_TOKEN=change-this-long-random-admin-password

# Optional fallback if you prefer Google Sheets instead of Supabase.
# GOOGLE_SHEET_ID=your_google_sheet_id
# GOOGLE_SHEET_TAB=Orders
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
